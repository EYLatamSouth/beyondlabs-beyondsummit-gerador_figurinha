{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "*.{css,scss,js,ts,tsx,png,jpg,jpeg,gif,svg,ico,wasm}"]
  },
  "mimeTypes": {
    ".wasm": "application/wasm"
  },
  "globalHeaders": {
    "Cross-Origin-Opener-Policy": "same-origin",
    "Cross-Origin-Embedder-Policy": "require-corp"
  }
}
