# Beyond Summit Figurinha Generator — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env

# URL base das Azure Functions
# Dev local (swa-cli): http://localhost:7071
# Produção: deixar vazio — Azure Static Web Apps resolve /api automaticamente
VITE_API_BASE_URL=http://localhost:7071

# Azure Blob Storage (Fase 1 — Mural)
# Connection string do Azure Blob Storage (obtida via Azure Key Vault em produção)
BLOB_CONNECTION_STRING=
# Nome da conta de storage (ex: beyondsummitstorage)
BLOB_ACCOUNT_NAME=
# Nome do container de figurinhas (padrão: stickers)
BLOB_CONTAINER_NAME=stickers
